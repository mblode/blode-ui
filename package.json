    "portless": "^0.15.1",
    "rehype": "^13.0.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "6.0.0",
    "remark-code-import": "^1.2.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.9.3",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0"
