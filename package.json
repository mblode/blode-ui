{
  "name": "blode-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run next dev --turbopack",
    "build": "npm run build:docs && npm run check:registry-deps && npm run build:registry && node scripts/build-well-known-skills.mjs && next build --turbopack",
    "build:docs": "content-collections build",
    "build:registry": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-registry.mts",
    "registry:build": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-registry.mts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check:types": "tsc --noEmit",
    "preview": "next build && next start -p 3333",
    "typecheck": "npm run build:docs && tsc --noEmit",
    "prepare": "lefthook install",
    "check": "npm run check:registry-deps && ultracite check",
    "check:registry-deps": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/check-registry-deps.mts",
    "fix": "ultracite fix",
    "knip": "knip",
    "knip:production": "knip --production --strict"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@next/third-parties": "^16.2.10",
    "@shadcn/react": "^0.2.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/lodash.template": "^4.5.3",
    "blode-icons-react": "^0.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "copy-to-clipboard": "^4.0.2",
    "critters": "^0.0.25",
    "date-fns": "4.4.0",
    "downshift": "9.4.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jotai": "^2.20.1",
    "lodash": "^4.18.1",
    "merge-refs": "^2.0.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "postcss": "8.5.17",
    "react": "19.2.7",
    "react-currency-input-field": "^4.0.5",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-phone-number-input": "^3.4.17",
    "react-resizable-panels": "^4.12.1",
    "react-textarea-autosize": "^8.5.9",
    "react-tweet": "^3.3.1",
    "recharts": "^3.9.2",
    "remark": "^15.0.1",
    "shadcn": "4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "ts-morph": "^28.0.0",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
